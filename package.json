{
  "name": "kritisi",
  "version": "1.6.2",
  "description": "A powerful AI-driven security audit tool for Solidity smart contracts, designed to detect vulnerabilities, enhance code quality, and ensure compliance with best practices. Ideal for developers seeking fast, reliable security insights.",
  "main": "src/index.js",
  "bin": {
    "kritisi": "src/index.js"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:help": "node ./src/index.js help"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zororaka00/kritisi.git"
  },
  "homepage": "https://github.com/zororaka00/kritisi/blob/main/README.md",
  "keywords": [
    "ethereum",
    "smart-contract",
    "solidity",
    "tooling",
    "ai",
    "chatgpt",
    "security",
    "audit",
    "blockchain",
    "vulnerability"
  ],
  "author": "Raka Widhi Antoro",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "node-fetch": "^2.7.0",
    "ora": "^9.3.0",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "sol-merger": "^4.4.2",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  }
}
